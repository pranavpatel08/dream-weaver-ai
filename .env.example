# Copy to .env.local (gitignored). Server-only secrets — never prefix with VITE_.

# Apify
APIFY_TOKEN=

# LLM (OpenAI-compatible). Defaults target Lovable AI Gateway.
# Lovable AI Gateway:
#   LLM_BASE_URL=https://ai.gateway.lovable.dev/v1
#   LLM_API_KEY=lov_...
#   LLM_MODEL_COORDINATOR=google/gemini-2.5-pro
#   LLM_MODEL_WORKER=google/gemini-3-flash-preview
# NVIDIA NIM:
#   LLM_BASE_URL=https://integrate.api.nvidia.com/v1
#   LLM_API_KEY=nvapi-...
#   LLM_MODEL_COORDINATOR=meta/llama-3.3-70b-instruct
#   LLM_MODEL_WORKER=meta/llama-3.1-8b-instruct
# OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-...
#   LLM_MODEL_COORDINATOR=gpt-4o
#   LLM_MODEL_WORKER=gpt-4o-mini

LLM_BASE_URL=https://ai.gateway.lovable.dev/v1
LLM_API_KEY=
LLM_MODEL_COORDINATOR=google/gemini-2.5-pro
LLM_MODEL_WORKER=google/gemini-3-flash-preview

# Demo controls
# When DEMO_MODE=1, the orchestrator can fall back to canned data if Apify or LLM fail.
# When MOCK_LLM=1, all LLM calls return canned responses from src/server/mocks.
DEMO_MODE=1
MOCK_LLM=0
